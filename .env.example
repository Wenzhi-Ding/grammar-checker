# Public env vars (safe to expose to the browser). Copy to .env.local and fill in.

# Canonical site URL (no trailing slash). Used for metadata, sitemap, robots, OG.
NEXT_PUBLIC_SITE_URL=https://grammar-checker.app

# Microsoft Clarity project ID. Leave empty in dev; set in Vercel for production.
# Get one at https://clarity.microsoft.com → New project.
NEXT_PUBLIC_CLARITY_ID=

# Google Search Console verification token (the content="" part of the meta tag).
# When set, layout.tsx emits <meta name="google-site-verification" content="<value>">.
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification token (content="" part of the meta tag).
# When set, layout.tsx emits <meta name="msvalidate.01" content="<value>">.
NEXT_PUBLIC_BING_VERIFICATION=
